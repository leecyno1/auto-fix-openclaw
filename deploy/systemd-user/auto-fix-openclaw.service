[Unit]
Description=auto-fix-openclaw periodic health check and auto repair
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=__AUTO_FIX_OPENCLAW_BIN__ run-once --source systemd-timer
Environment=HOME=%h
Environment="PATH=%h/.local/bin:%h/.npm-global/bin:%h/.nvm/current/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=-%h/.config/openclaw/auto-fix-openclaw.env
TimeoutStartSec=420
