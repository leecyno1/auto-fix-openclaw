# auto-fix-openclaw runtime configuration
# Copy to: ~/.config/openclaw/auto-fix-openclaw.env

# Core scheduler guards
AUTO_FIX_OPENCLAW_CHECK_INTERVAL_SECS=60
AUTO_FIX_OPENCLAW_REPAIR_COOLDOWN_SECS=300
AUTO_FIX_OPENCLAW_MAX_DAILY_REPAIRS=24
AUTO_FIX_OPENCLAW_MAX_CONSECUTIVE_FAILURES=6

# Reconcile (replay local customizations)
AUTO_FIX_OPENCLAW_RECONCILE_ON_VERSION_CHANGE=1
AUTO_FIX_OPENCLAW_RECONCILE_ON_UNHEALTHY=1
AUTO_FIX_OPENCLAW_RECONCILE_TIMEOUT_SECS=420
# AUTO_FIX_OPENCLAW_RECONCILE_CMD=$HOME/.local/share/auto-fix-openclaw/scripts/reconcile-openclaw-custom.sh

# Custom patch capture (baseline + overlay + patch-manifest.json)
AUTO_FIX_OPENCLAW_CAPTURE_ON_HEALTHY=1
# AUTO_FIX_OPENCLAW_CAPTURE_CMD=$HOME/.local/share/auto-fix-openclaw/scripts/capture-openclaw-custom.sh\ capture
AUTO_FIX_OPENCLAW_CAPTURE_INTERVAL_SECS=21600
AUTO_FIX_OPENCLAW_CAPTURE_TIMEOUT_SECS=300

# Notification routing
# format: channel:target or channel:target:account
# example: feishu:oc_xxx,telegram:-1001234567890,discord:123456789012345678
AUTO_FIX_OPENCLAW_NOTIFY_ENDPOINTS=
AUTO_FIX_OPENCLAW_NOTIFY_ACCOUNT=
# notify event levels: failed,recovered,skipped,reconcile
AUTO_FIX_OPENCLAW_NOTIFY_ON=failed,recovered,reconcile

# AI repair providers
# codex | cloudcode | disabled
AUTO_FIX_OPENCLAW_REPAIR_PROVIDER=codex
AUTO_FIX_OPENCLAW_REPAIR_PROVIDER_FALLBACK=cloudcode
AUTO_FIX_OPENCLAW_REPAIR_PROVIDER_TIMEOUT_SECS=420

# Codex settings
AUTO_FIX_OPENCLAW_CODEX_BIN=/opt/homebrew/bin/codex
AUTO_FIX_OPENCLAW_CODEX_MODEL=gpt-5-codex
AUTO_FIX_OPENCLAW_CODEX_TIMEOUT_SECS=240

# Cloud Code settings
AUTO_FIX_OPENCLAW_CLOUD_CODE_BIN=cloud-code
AUTO_FIX_OPENCLAW_CLOUD_CODE_MODEL=
AUTO_FIX_OPENCLAW_CLOUD_CODE_TIMEOUT_SECS=300
AUTO_FIX_OPENCLAW_CLOUD_CODE_ARGS_TEMPLATE='exec --full-auto --cwd "{CWD}" --prompt-file "{PROMPT_FILE}" --model "{MODEL}"'

# Safety controls for AI edits
AUTO_FIX_OPENCLAW_SAFE_PATHS=$HOME/.openclaw:$HOME/clawd

# Diagnostics only mode (1 = do not mutate services)
AUTO_FIX_OPENCLAW_DRY_RUN=0

# Optional compatibility knobs (legacy fix-my-claw)
# FIX_MY_CLAW_ENABLE_CODEX_FIX=1
# FIX_MY_CLAW_NOTIFY_ENDPOINTS=telegram:-1000000000000
